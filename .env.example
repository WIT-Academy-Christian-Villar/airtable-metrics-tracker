PORT=3000
NODE_ENV=development
LOG_LEVEL=info
AIRTABLE_API_BASE=https://api.airtable.com/v0
AIRTABLE_TOKEN=
REQUEST_TIMEOUT_MS=30000
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_MS=500
RETRY_MAX_MS=4000
AIRTABLE_DRY_RUN_DEFAULT=true
EVENT_DEDUP_TTL_MS=86400000
DEFAULT_TIMEZONE=America/Argentina/Buenos_Aires

# Sitio principal
MAIN_SITE_KEY=marketing-main
MAIN_SITE_DISPLAY_NAME=Marketing Main
MAIN_SITE_BASE_URL=https://example.com
MAIN_SITE_ALLOWED_HOSTS=example.com,www.example.com
MAIN_SITE_VISITS_URL=
MAIN_SITE_VISITS_TOKEN=
MAIN_SITE_REGISTRATIONS_URL=
MAIN_SITE_REGISTRATIONS_TOKEN=
MAIN_SITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_TABLE_ID=tblXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_SITE_KEY=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_ROUTE=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_DATE_BUCKET=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_VISITS=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_REGISTRATIONS=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_UTM_SOURCE=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_UTM_MEDIUM=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_UTM_CAMPAIGN=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_UTM_TERM=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_UTM_CONTENT=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_SOURCES=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_CAPTURED_AT=fldXXXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_FIELD_SYNC_KEY=fldXXXXXXXXXXXXXXXX

# Sitio secundario opcional
PRICING_SITE_KEY=pricing-site
PRICING_SITE_DISPLAY_NAME=Pricing Site
PRICING_SITE_BASE_URL=
PRICING_SITE_ALLOWED_HOSTS=
PRICING_SITE_VISITS_URL=
PRICING_SITE_VISITS_TOKEN=
PRICING_SITE_REGISTRATIONS_URL=
PRICING_SITE_REGISTRATIONS_TOKEN=
PRICING_SITE_AIRTABLE_BASE_ID=appYYYYYYYYYYYYYY
PRICING_SITE_AIRTABLE_TABLE_ID=tblYYYYYYYYYYYYYY
PRICING_SITE_AIRTABLE_FIELD_SITE_KEY=
PRICING_SITE_AIRTABLE_FIELD_ROUTE=
PRICING_SITE_AIRTABLE_FIELD_DATE_BUCKET=
PRICING_SITE_AIRTABLE_FIELD_VISITS=
PRICING_SITE_AIRTABLE_FIELD_REGISTRATIONS=
PRICING_SITE_AIRTABLE_FIELD_UTM_SOURCE=
PRICING_SITE_AIRTABLE_FIELD_UTM_MEDIUM=
PRICING_SITE_AIRTABLE_FIELD_UTM_CAMPAIGN=
PRICING_SITE_AIRTABLE_FIELD_UTM_TERM=
PRICING_SITE_AIRTABLE_FIELD_UTM_CONTENT=
PRICING_SITE_AIRTABLE_FIELD_SOURCES=
PRICING_SITE_AIRTABLE_FIELD_CAPTURED_AT=
PRICING_SITE_AIRTABLE_FIELD_SYNC_KEY=

# Alternativa opcional: definir todos los sitios via JSON.
# SITES_CONFIG_JSON=[{"siteKey":"marketing-main","displayName":"Marketing Main","enabled":true,"providers":{"visits":{"key":"noop-visits","config":{}},"registrations":{"key":"noop-registrations","config":{}}},"routeRules":{"baseUrl":"https://example.com","allowedHosts":["example.com","www.example.com"],"fallbackRoute":"/","stripTrailingSlash":true},"utmMapping":{"source":["utm_source","source"],"medium":["utm_medium","medium"],"campaign":["utm_campaign","campaign"],"term":["utm_term","term"],"content":["utm_content","content"]},"airtable":{"baseId":"appXXXXXXXXXXXXXX","tableId":"tblXXXXXXXXXXXXXX","fieldIds":{"siteKey":"fldXXXXXXXXXXXXXXXX","route":"fldXXXXXXXXXXXXXXXX","dateBucket":"fldXXXXXXXXXXXXXXXX","visits":"fldXXXXXXXXXXXXXXXX","registrations":"fldXXXXXXXXXXXXXXXX","utmSource":"fldXXXXXXXXXXXXXXXX","utmMedium":"fldXXXXXXXXXXXXXXXX","utmCampaign":"fldXXXXXXXXXXXXXXXX","utmTerm":"fldXXXXXXXXXXXXXXXX","utmContent":"fldXXXXXXXXXXXXXXXX","sources":"fldXXXXXXXXXXXXXXXX","capturedAt":"fldXXXXXXXXXXXXXXXX","syncKey":"fldXXXXXXXXXXXXXXXX"},"upsertFieldIds":["fldXXXXXXXXXXXXXXXX"]}}]
