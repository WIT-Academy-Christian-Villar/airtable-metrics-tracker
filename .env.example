PORT=3000
NODE_ENV=development
LOG_LEVEL=info
AIRTABLE_API_BASE=https://api.airtable.com/v0
AIRTABLE_TOKEN=
REQUEST_TIMEOUT_MS=30000
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_MS=500
RETRY_MAX_MS=4000
AIRTABLE_DRY_RUN_DEFAULT=true
EVENT_DEDUP_TTL_MS=86400000
DEFAULT_TIMEZONE=UTC

# Sitio de ejemplo 1
MAIN_SITE_VISITS_URL=https://analytics.example.com/api/routes
MAIN_SITE_VISITS_TOKEN=
MAIN_SITE_REGISTRATIONS_URL=https://forms.example.com/api/submissions
MAIN_SITE_REGISTRATIONS_TOKEN=
MAIN_SITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
MAIN_SITE_AIRTABLE_TABLE=Traffic Metrics

# Sitio de ejemplo 2
PRICING_SITE_VISITS_URL=https://plausible.example.com/api/pricing
PRICING_SITE_VISITS_TOKEN=
PRICING_SITE_REGISTRATIONS_URL=https://crm.example.com/api/registrations
PRICING_SITE_REGISTRATIONS_TOKEN=
PRICING_SITE_AIRTABLE_BASE_ID=appYYYYYYYYYYYYYY
PRICING_SITE_AIRTABLE_TABLE=Traffic Metrics

# Alternativa opcional: definir todos los sitios via JSON.
# SITES_CONFIG_JSON=[{"siteKey":"marketing-main","displayName":"Marketing Main","enabled":true,"providers":{"visits":{"key":"json-api-visits","config":{"endpoint":"https://analytics.example.com/api/routes","headers":{"Authorization":"Bearer token"}}},"registrations":{"key":"json-api-registrations","config":{"endpoint":"https://forms.example.com/api/submissions","headers":{"Authorization":"Bearer token"}}}},"routeRules":{"fallbackRoute":"/","stripTrailingSlash":true},"utmMapping":{"source":["utm_source","source"],"medium":["utm_medium","medium"],"campaign":["utm_campaign","campaign"],"term":["utm_term","term"],"content":["utm_content","content"]},"airtable":{"baseId":"appXXXXXXXXXXXXXX","tableName":"Traffic Metrics"}}]
